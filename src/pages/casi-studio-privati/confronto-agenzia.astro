---
import Layout from '../../layouts/Layout.astro';

const calendlyUrl = 'https://app.reclaim.ai/m/davide-veneto/call-conoscitiva';
const PASSWORD = 'casistudioprivati';
---

<Layout title="Strategia vs Scorciatoia — Caso Studio | Davide Veneto" description="Analisi dati reali: cosa succede quando un cliente interrompe una collaborazione per testare un'agenzia esterna.">

	<!-- AUTH CHECK -->
	<div id="locked" class="min-h-screen flex items-center justify-center px-6">
		<div class="max-w-md w-full">
			<div class="section-divider mb-8"></div>
			<h1 class="text-3xl font-heading mb-3">Contenuto <span class="text-red">riservato</span></h1>
			<p class="text-gray-400 mb-8">Torna all'indice e inserisci la password per accedere.</p>
			<a href="/casi-studio-privati/" class="btn-primary inline-block">Vai all'accesso</a>
		</div>
	</div>

	<!-- CONTENT -->
	<div id="content" class="hidden">

		<!-- HERO -->
		<section class="pt-32 pb-20 md:pt-40 md:pb-28 relative">
			<div class="max-w-3xl mx-auto px-6">
				<a href="/casi-studio-privati/" class="text-red font-heading text-sm tracking-[0.2em] mb-6 inline-block hover:text-red-glow transition-colors">← CASI STUDIO PRIVATI</a>
				<p class="text-red font-heading text-sm tracking-[0.2em] mb-4">CASO STUDIO — SERRAMENTI</p>
				<h1 class="text-4xl md:text-6xl leading-[1.1] mb-6" style="font-family: 'DM Serif Display', serif;">
					Quando si scambia<br />
					<em>la strategia con la scorciatoia.</em>
				</h1>
				<p class="text-gray-300 text-lg md:text-xl leading-relaxed mb-8">
					Un'analisi dei dati reali di un cliente che ha interrotto la collaborazione per testare "nuovi metodi". Ecco com'è andata.
				</p>
				<div class="flex flex-wrap gap-4 text-sm">
					<span class="px-3 py-1 border border-gray-700/50 text-gray-400">Settore: Infissi</span>
					<span class="px-3 py-1 border border-gray-700/50 text-gray-400">Canale: Meta Ads</span>
					<span class="px-3 py-1 border border-gray-700/50 text-gray-400">Obiettivo: Lead generation</span>
				</div>
				<div class="w-20 h-1 bg-red mt-10"></div>
			</div>
		</section>

		<!-- CONFRONTO -->
		<section class="py-16 md:py-24 bg-black-light border-t border-b border-white/5">
			<div class="max-w-3xl mx-auto px-6">
				<div class="section-divider mb-8"></div>
				<h2 class="text-3xl md:text-4xl font-heading mb-8">Il <span class="text-red">confronto</span></h2>

				<div class="grid md:grid-cols-2 gap-4">
					<!-- Mia gestione -->
					<div class="p-6 bg-black-card border border-[#22c55e]/40">
						<div class="flex items-center gap-2 mb-5">
							<span class="w-2 h-2 rounded-full bg-[#22c55e]"></span>
							<p class="text-[#22c55e] font-heading text-sm tracking-widest">LA MIA GESTIONE</p>
						</div>
						<p class="text-gray-500 text-xs mb-4">Novembre 2025 — Black Friday. CPM ai massimi storici. Massima pressione pubblicitaria.</p>
						<div class="space-y-3">
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Contatti generati</span>
								<span class="text-white font-heading text-xl">269</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Costo per lead</span>
								<span class="text-white font-heading text-xl">~10€</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Sopralluoghi fissati</span>
								<span class="text-[#22c55e] font-heading text-xl">60%</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Tasso di chiusura</span>
								<span class="text-[#22c55e] font-heading text-xl">26%</span>
							</div>
							<div class="flex justify-between items-center">
								<span class="text-gray-400 text-sm">Strategia</span>
								<span class="text-white text-sm text-right max-w-[160px]">Moduli Meta con 7 domande di qualificazione</span>
							</div>
						</div>
					</div>

					<!-- Agenzia esterna -->
					<div class="p-6 bg-black-card border border-red/40">
						<div class="flex items-center gap-2 mb-5">
							<span class="w-2 h-2 rounded-full bg-red"></span>
							<p class="text-red font-heading text-sm tracking-widest">AGENZIA ESTERNA</p>
						</div>
						<p class="text-gray-500 text-xs mb-4">Febbraio 2026 — Mese standard. Mercato meno saturo. Condizioni più favorevoli.</p>
						<div class="space-y-3">
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Contatti generati</span>
								<span class="text-red font-heading text-xl">153</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Costo per lead</span>
								<span class="text-red font-heading text-xl">20,14€</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Sopralluoghi fissati</span>
								<span class="text-gray-500 font-heading text-xl">n.d.</span>
							</div>
							<div class="flex justify-between items-center border-b border-gray-700/30 pb-3">
								<span class="text-gray-400 text-sm">Tasso di chiusura</span>
								<span class="text-gray-500 font-heading text-xl">n.d.</span>
							</div>
							<div class="flex justify-between items-center">
								<span class="text-gray-400 text-sm">Strategia</span>
								<span class="text-white text-sm text-right max-w-[160px]">Moduli aperti, zero filtri</span>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- LA COSA ASSURDA -->
		<section class="py-16 md:py-24">
			<div class="max-w-3xl mx-auto px-6">
				<div class="p-6 md:p-8 border border-[#22c55e]/40 bg-[#22c55e]/5 border-l-4 border-l-[#22c55e]">
					<p class="text-[#22c55e] font-heading text-sm tracking-widest mb-4">LA COSA ASSURDA</p>
					<p class="text-white text-lg md:text-xl leading-relaxed" style="font-family: 'DM Serif Display', serif;">
						La nuova agenzia ha rimosso i filtri di qualificazione — quelli che normalmente alzano il CPL. Eppure il costo per contatto è raddoppiato. In un mese più facile. Con meno concorrenza.
					</p>
					<p class="text-gray-300 mt-4">Il problema non era il budget: era la competenza.</p>
				</div>
			</div>
		</section>

		<!-- COSA È SUCCESSO DAVVERO -->
		<section class="py-16 md:py-24 bg-black-light border-t border-b border-white/5">
			<div class="max-w-3xl mx-auto px-6">
				<div class="section-divider mb-8"></div>
				<h2 class="text-3xl md:text-4xl font-heading mb-8">Cosa è successo <span class="text-red">davvero</span></h2>
				<div class="space-y-5 text-gray-300 text-lg leading-relaxed">
					<p>Quando sei il primo a strutturare il marketing di un'azienda, il cliente non ha un termine di paragone. È il momento più delicato: si lavora bene, i risultati arrivano, ma senza un confronto diretto è difficile capire cosa vale.</p>
					<p>Questo cliente ha deciso di testare un'alternativa. Capisco. A volte si vuole confrontare. Il problema è che interrompere mesi di ottimizzazione dati per inseguire una promessa migliore <strong class="text-white">distrugge un patrimonio costruito nel tempo</strong>.</p>
					<p>Il reparto commerciale si è ritrovato sommerso da contatti inutili — cercatori di prezzo, perditempo — con il CAC che saliva senza possibilità di recupero.</p>
				</div>
			</div>
		</section>

		<!-- PERCHÉ HO RIFIUTATO DI RIENTRARE -->
		<section class="py-16 md:py-24">
			<div class="max-w-3xl mx-auto px-6">
				<div class="section-divider mb-8"></div>
				<h2 class="text-3xl md:text-4xl font-heading mb-8">Perché ho rifiutato <span class="text-red">di rientrare</span></h2>
				<div class="space-y-4">
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl shrink-0">01</span>
						<div>
							<p class="text-white font-semibold mb-1">Il marketing non è un jukebox</p>
							<p class="text-gray-300">Non si inserisce un gettone e parte la musica. C'è una strategia di lungo periodo dietro ogni risultato. Interrompere quel lavoro e aspettarsi di ricominciare da dove ci si era fermati non funziona così.</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl shrink-0">02</span>
						<div>
							<p class="text-white font-semibold mb-1">Strategia, non magia</p>
							<p class="text-gray-300">Se un imprenditore cerca il "mago", non è il partner adatto al mio modo di lavorare. I risultati si costruiscono con metodo e tempo, non con scorciatoie.</p>
						</div>
					</div>
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl shrink-0">03</span>
						<div>
							<p class="text-white font-semibold mb-1">Selezione, non accoglienza</p>
							<p class="text-gray-300">Lavorare con pochi clienti giusti mi permette di dare il 100% a chi crede nel valore di una collaborazione seria e di lungo periodo. Allargare per riaccogliere chi è andato non ha senso.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- CHIUSURA -->
		<section class="py-16 md:py-24 bg-black-light border-t border-white/5">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<p class="text-white text-2xl md:text-3xl" style="font-family: 'DM Serif Display', serif;">
					"Sai quello che lasci, non sai quello che trovi."
				</p>
			</div>
		</section>

		<!-- CTA -->
		<section class="py-24 md:py-40 bg-red relative overflow-hidden">
			<div class="max-w-3xl mx-auto px-6 text-center relative">
				<div class="w-20 h-1 bg-white/30 mb-8 mx-auto"></div>
				<h2 class="text-4xl md:text-5xl font-heading mb-6 text-white">
					Preferisci non scoprirlo<br />nel modo difficile?
				</h2>
				<p class="text-white/80 text-lg mb-10">
					30 minuti per capire se ha senso lavorare insieme.
				</p>
				<a href={calendlyUrl} target="_blank" rel="noopener noreferrer" class="btn-primary-inverted">
					Prenota una call — 30 minuti
				</a>
			</div>
		</section>

		<footer class="py-8 border-t border-gray-700/30">
			<div class="max-w-6xl mx-auto px-6 text-center">
				<p class="text-gray-500 text-sm">&copy; {new Date().getFullYear()} Power Adv di Veneto Davide</p>
			</div>
		</footer>

	</div>

	<script define:vars={{ PASSWORD }}>
		const stored = localStorage.getItem('cs_privati_auth');
		const locked = document.getElementById('locked');
		const content = document.getElementById('content');

		if (stored === PASSWORD) {
			locked.classList.add('hidden');
			content.classList.remove('hidden');
		}
	</script>

</Layout>
