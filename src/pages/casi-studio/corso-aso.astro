---
import Layout from '../../layouts/Layout.astro';
import statsLanding from '../../assets/photos/formazione1.webp';
import chatResults from '../../assets/photos/formazione2.webp';
import adCreativa from '../../assets/photos/formazione3.webp';

const calendlyUrl = 'https://app.reclaim.ai/m/davide-veneto/call-conoscitiva';
---

<Layout
	title="ROAS 4x — Corso ASO venduto al doppio del prezzo | Powerads"
	description="Come abbiamo venduto un corso di formazione al doppio del prezzo dei competitor con un ritorno di 4€ per ogni 1€ investito."
>
	<!-- HERO -->
	<section class="pt-32 pb-20 md:pt-40 md:pb-28 relative">
		<div class="max-w-3xl mx-auto px-6">
			<a href="/" class="text-red font-heading text-sm tracking-[0.2em] mb-6 inline-block hover:text-red-glow transition-colors">← TORNA ALLA HOME</a>
			<p class="text-red font-heading text-lg tracking-[0.2em] mb-4">FORMAZIONE</p>
			<h1 class="text-4xl md:text-6xl font-heading leading-[0.95] mb-6">
				4€ di ritorno<br />
				<span class="text-red">per ogni 1€ investito</span>
			</h1>
			<p class="text-gray-300 text-lg md:text-xl leading-relaxed">
				Come abbiamo venduto un corso di formazione al doppio del prezzo dei competitor, generando un ROAS 4x.
			</p>
			<div class="w-20 h-1 bg-red mt-8"></div>
		</div>
	</section>

	<!-- CONTESTO -->
	<section class="py-16 md:py-24 bg-black-light border-t border-b border-white/5">
		<div class="max-w-3xl mx-auto px-6">
			<h2 class="text-3xl md:text-4xl font-heading mb-8">Il contesto</h2>
			<div class="space-y-6 text-gray-300 text-lg leading-relaxed">
				<p>Il cliente vende un corso di formazione per assistenti alla poltrona nel settore dentale. Il corso è obbligatorio e il target è abituato a farlo online, pagando dai 50 ai 60€.</p>
			</div>

			<div class="grid sm:grid-cols-3 gap-4 mt-8">
				<div class="p-5 bg-black-card border border-gray-700/50">
					<p class="text-red font-heading text-sm tracking-wider mb-2">PRODOTTO</p>
					<p class="text-white font-semibold">In presenza, a circa il doppio del prezzo</p>
				</div>
				<div class="p-5 bg-black-card border border-gray-700/50">
					<p class="text-red font-heading text-sm tracking-wider mb-2">MERCATO</p>
					<p class="text-white font-semibold">Offerta "standard", argomenti visti e rivisti</p>
				</div>
				<div class="p-5 bg-black-card border border-gray-700/50">
					<p class="text-red font-heading text-sm tracking-wider mb-2">UNICITÀ</p>
					<p class="text-white font-semibold">Il passo successivo: formazione manageriale</p>
				</div>
			</div>
		</div>
	</section>

	<!-- ANALISI TARGET -->
	<section class="py-16 md:py-24">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-8"></div>
			<h2 class="text-3xl md:text-4xl font-heading mb-8">Analisi del <span class="text-red">target</span></h2>
			<div class="p-6 bg-black-card border border-red/20">
				<p class="text-white text-lg leading-relaxed">Maggioranza di ragazze che pensano di poter dare di più, ma non si sentono valorizzate. L'ho scoperto dalle risposte che davano entrando nel gruppo Facebook gratuito del cliente.</p>
			</div>
		</div>
	</section>

	<!-- STRATEGIA -->
	<section class="py-16 md:py-24 bg-black-light border-t border-b border-white/5">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-8"></div>
			<h2 class="text-3xl md:text-4xl font-heading mb-8">La <span class="text-red">strategia</span></h2>
			<div class="space-y-6 text-gray-300 text-lg leading-relaxed">
				<p class="text-white font-semibold">Come ci siamo differenziati?</p>
				<p>Ho detto al mio cliente di mettere delle informazioni del percorso manageriale in quello obbligatorio, per poterlo differenziare e fare leva sull'insoddisfazione e la ripetitività dei corsi dei competitor.</p>

				<div class="grid gap-4 mt-6">
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl">01</span>
						<p class="text-gray-300">Ho scritto e realizzato la landing page</p>
					</div>
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl">02</span>
						<p class="text-gray-300">Ho creato inserzioni su Facebook e Instagram</p>
					</div>
					<div class="flex items-start gap-4 p-5 bg-black-card border border-gray-700/50">
						<span class="text-red font-heading text-2xl">03</span>
						<p class="text-gray-300">Spendiamo circa 50€/giorno e prendiamo 2 contatti. Il 90% di questi contatti fa domande a un consulente e viene al corso.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- RISULTATI -->
	<section class="py-16 md:py-24">
		<div class="max-w-3xl mx-auto px-6">
			<div class="section-divider mb-8 mx-auto text-center"></div>
			<h2 class="text-3xl md:text-4xl font-heading mb-8 text-center">I <span class="text-red">risultati</span></h2>
			<div class="p-8 bg-red/10 border border-red/30 text-center mb-8">
				<p class="text-red font-heading text-5xl md:text-6xl mb-4">ROAS 4x</p>
				<p class="text-white text-xl">Ogni euro investito ne fatturava 4. In sala venivano proposti degli upsell.</p>
			</div>

			<!-- Stats e prove -->
			<div class="grid sm:grid-cols-2 gap-6">
				<div>
					<p class="text-red font-heading text-sm tracking-wider mb-3">STATS LANDING PAGE</p>
					<img src={(statsLanding as any).src ?? statsLanding} alt="Statistiche landing page corso ASO" class="w-full rounded border border-gray-700/50" />
				</div>
				<div>
					<p class="text-red font-heading text-sm tracking-wider mb-3">RISULTATI REALI</p>
					<img src={(chatResults as any).src ?? chatResults} alt="Chat WhatsApp con risultati vendita" class="w-full rounded border border-gray-700/50" />
				</div>
			</div>

			<!-- Creatività -->
			<div class="mt-8">
				<p class="text-red font-heading text-sm tracking-wider mb-3">LA CREATIVITÀ CHE HA PORTATO PIÙ CONTATTI</p>
				<img src={(adCreativa as any).src ?? adCreativa} alt="Creatività ads corso ASO" class="w-full max-w-md mx-auto rounded border border-gray-700/50" />
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="py-24 md:py-40 bg-red relative overflow-hidden">
		<div class="max-w-3xl mx-auto px-6 text-center relative">
			<div class="w-20 h-1 bg-white/30 mb-8 mx-auto"></div>
			<h2 class="text-4xl md:text-5xl font-heading mb-6 text-white">
				Vuoi risultati simili<br />per il tuo business?
			</h2>
			<p class="text-white/80 text-lg mb-10">
				Prenota una chiamata gratuita di 30 minuti. Analizziamo insieme la tua situazione.
			</p>
			<a href={calendlyUrl} target="_blank" rel="noopener noreferrer" class="btn-primary-inverted">
				Prenota una call gratuita
			</a>
		</div>
	</section>

	<footer class="py-8 border-t border-gray-700/30">
		<div class="max-w-6xl mx-auto px-6 text-center">
			<p class="text-gray-500 text-sm">&copy; {new Date().getFullYear()} Davide Veneto — Powerads. Tutti i diritti riservati.</p>
		</div>
	</footer>
</Layout>
